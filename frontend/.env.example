# FastAPI backend URL (proxied in dev via vite.config.ts)
VITE_API_BASE_URL=http://localhost:8000

# Redis is configured on the backend only (backend/.env → REDIS_URL). No VITE_* Redis vars.

# Supabase (used for the Supabase JS client — optional if all auth goes through FastAPI)
# Use the anon key only (never service_role). Leave blank if unused.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=
