# Use frontend/.env only, OR .env.local only — not both with different Supabase URLs.
# Vite merges env files; .env.local overrides .env in dev (same variable names).
# Do not set VITE_SUPABASE_* to 127.0.0.1:54321 unless you run local Supabase CLI.

# FastAPI backend URL
VITE_API_BASE_URL=http://localhost:8080

# Cloud Supabase (copy SUPABASE_URL + SUPABASE_ANON_KEY from backend/.env)
# Or run: frontend/scripts/sync-env-from-backend.ps1
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Public anon key only (never use service-role key in frontend env)
VITE_SUPABASE_ANON_KEY=

# Enable Supabase Realtime for live portal sync
VITE_USE_REALTIME=true
