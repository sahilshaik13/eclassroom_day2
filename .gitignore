# ─── Environment & secrets (never commit real keys) ──────────────────────────
.env
.env.*
!.env.example
!.env.sample
!.env.template
!.env.*.example

# Tool-specific env loaders that often hold secrets
.envrc
.direnv/

# Key material & cloud credential files
*.pem
*.key
!*.pem.example
*-private-key.json
credentials.json
**/credentials.json
service-account*.json
**/service-account*.json
*.keystore
*.jks

# Local / backup env copies (explicit; also covered by .env.* above)
*.env.backup
*.env.bak

rediscli.txt

# Python
__pycache__/
*.pyc
*.pyo
venv/
env/
.venv/

# Node
node_modules/
dist/
build/
coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# AI / Agents / IDEs
.agents/
.claude/
.gitnexus/
.cursor/
.windsurf/
.vscode/
.idea/

# Documents
*.md
!README.md
!readme.md
!Readme.md

# Local notes / exports / walkthroughs (do not commit)
*.pdf
*.csv
walkthrough*
*walkthrough*

skills-lock.json

envsec/