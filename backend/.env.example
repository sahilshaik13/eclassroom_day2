# ─── Supabase ─────────────────────────────────────────────────────────────────
# From: Supabase Dashboard → Settings → API

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Paste keys from Supabase Dashboard → Settings → API (do not commit real values)
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional newer API keys (only if your project/tools require them)
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# JWT Secret — from Supabase Dashboard → Settings → API → JWT Secret
# FastAPI uses this to verify Supabase-issued JWTs without a network call
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Do NOT use local Supabase (127.0.0.1:54321) or local Postgres/Redis for this app.

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_NAME=ThinkTarteeb E-Classroom
API_PORT=8080
FRONTEND_URL=http://localhost:5174
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://127.0.0.1:5173","http://127.0.0.1:5174","https://eclassroom-day2-afok.vercel.app"]
# Allow dynamic preview hosts (Vercel). Override with empty value to disable.
CORS_ORIGIN_REGEX=^https://([a-z0-9-]+\.)*vercel\.app$

# Enable Supabase Realtime (competitions, study plan, attendance). Sync to frontend via:
#   frontend/scripts/sync-env-from-backend.ps1  →  VITE_USE_REALTIME + VITE_SUPABASE_*
USE_SUPABASE_REALTIME=true

# ─── Session TTLs per role (minutes) ─────────────────────────────────────────
# These must match the JWT expiry configured in Supabase Auth settings
SESSION_STUDENT_TTL_MINUTES=10080   # 7 days
SESSION_TEACHER_TTL_MINUTES=1440    # 24h
SESSION_ADMIN_TTL_MINUTES=480       # 8h

# ─── OTP (Supabase handles this — these are just for the rate-limit overlay) ──
OTP_MAX_ATTEMPTS=3
OTP_LOCKOUT_MINUTES=15
# Student login: enable (default) | disable (phone-only, no SMS — dev only)
OTP=enable

# ─── Twilio (configure in Supabase Dashboard → Auth → Phone, OR set here) ────
# Supabase can use its own Twilio integration (recommended).
# Only fill these if building a custom OTP fallback.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+15005550006
TWILIO_MESSAGING_SERVICE_SID=

# ─── SMTP (application rejection emails — match Supabase Custom SMTP) ─────────
# Supabase Dashboard → Project Settings → Authentication → SMTP Settings
# Used when admin rejects a teacher application, or sends application approved notice.
# Direct teacher invites use Supabase "Invite user" template instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=ThinkTarteeb E-Classroom
SMTP_USE_TLS=true
# Port 465 uses implicit SSL automatically; port 587 uses STARTTLS when SMTP_USE_TLS=true
SMTP_USE_SSL=false

# No Gemini, Vertex, or Anthropic keys required.
NEXUSOCR_API_URL=https://nexusocr-backend-637895872255.asia-south1.run.app
NEXUSOCR_API_KEY=
NEXUSOCR_TIMEOUT_SECONDS=180

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_API=100/minute
GATEWAY_ENABLED=true

# ─── Redis Cloud (study-plan SSE, ARQ worker, response cache, rate limits) ───
# Must be a hosted URL — never redis://127.0.0.1:6379 or redis://localhost
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_REDIS_HOST:6379

# ─── Neon Postgres (super-admin application logs) + Redis SSE live tail ───────
# Logs are written to Neon; live updates use Redis pub/sub (not Supabase Realtime).
# Must be Neon/cloud — never postgresql://localhost or 127.0.0.1
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
AUDIT_LOG_RETENTION_DAYS=7
AUDIT_LOG_MAX_ENTRIES=500000

# ─── Google Meet (Calendar API + teacher OAuth) ───────────────────────────────
# GCP project: thinktarteeb-e-classroom
# OAuth client: APIs & Services → Credentials → Web client (ThinkTarteeb Meet)
# Service account JSON is NOT used for Meet (teacher OAuth only).
# Redirect URI must match exactly (add production URL when deploying):
#   http://localhost:8080/api/v1/meet/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/v1/meet/google/callback
# Optional Fernet key for refresh-token encryption; if empty, derived from SUPABASE_JWT_SECRET
GOOGLE_TOKEN_ENCRYPTION_KEY=

# ─── Sentry (optional) ────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# ─── Ops: run API + ARQ worker (study-plan OCR, cron jobs) ───────────────────
# Local dev — two terminals:
#   uvicorn app.main:app --reload --port 8080
#   arq app.worker.settings.WorkerSettings
# Render free tier (one Web Service, no paid Background Worker):
#   bash scripts/start_render_web_with_worker.sh
# Apply migrations 030–036 via Supabase CLI or SQL editor before production.
# Cron (in worker): MV refresh, cache rewarm, study-plan day unlock, audit rotation,
# database keepalive (daily 04:30 UTC). API also pings DB on startup + every 24h.

